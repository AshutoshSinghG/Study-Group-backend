{
	"info": {
		"_postman_id": "b3e34b5c-897b-4886-8208-9df2c21d015c",
		"name": "Group Study Backend",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Mock Google Login",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user1@gmail.com\",\n  \"name\": \"User One\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/auth/mock-google-login",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "auth", "mock-google-login" ]
						}
					}
				}
			]
		},
		{
			"name": "Groups",
			"item": [
				{
					"name": "Create Group",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Algebra Study Group\",\n  \"members\": [\"user2@gmail.com\", \"user3@gmail.com\"]\n}"
						},
						"url": {
							"raw": "http://localhost:5000/groups",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups" ]
						}
					}
				},
				{
					"name": "Add Member",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user4@gmail.com\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/groups/:id/member",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups", ":id", "member" ],
							"variable": [
								{ "key": "id", "value": "REPLACE_WITH_GROUP_ID" }
							]
						}
					}
				},
				{
					"name": "Add Goal",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Solve 100 Math Questions\",\n  \"subject\": \"Math\",\n  \"metric\": \"questionsSolved\",\n  \"target\": 100,\n  \"deadline\": \"2025-09-05T23:59:59Z\"\n}"
						},
						"url": {
							"raw": "http://localhost:5000/groups/:id/goal",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups", ":id", "goal" ],
							"variable": [
								{ "key": "id", "value": "REPLACE_WITH_GROUP_ID" }
							]
						}
					}
				},
				{
					"name": "Record Activity",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"questionId\": \"REPLACE_WITH_QUESTION_ID\",\n  \"status\": \"solved\",\n  \"timeSpent\": 120\n}"
						},
						"url": {
							"raw": "http://localhost:5000/groups/:id/activity",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups", ":id", "activity" ],
							"variable": [
								{ "key": "id", "value": "REPLACE_WITH_GROUP_ID" }
							]
						}
					}
				},
				{
					"name": "Get Leaderboard",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "http://localhost:5000/groups/:id/leaderboard?metric=questionsSolved&sort=desc&timeWindow=weekly&offset=0&limit=10",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups", ":id", "leaderboard" ],
							"query": [
								{ "key": "metric", "value": "questionsSolved" },
								{ "key": "sort", "value": "desc" },
								{ "key": "timeWindow", "value": "weekly" },
								{ "key": "offset", "value": "0" },
								{ "key": "limit", "value": "10" }
							],
							"variable": [
								{ "key": "id", "value": "REPLACE_WITH_GROUP_ID" }
							]
						}
					}
				},
				{
					"name": "Get Progress",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "http://localhost:5000/groups/:id/progress",
							"protocol": "http",
							"host": [ "localhost" ],
							"port": "5000",
							"path": [ "groups", ":id", "progress" ],
							"variable": [
								{ "key": "id", "value": "REPLACE_WITH_GROUP_ID" }
							]
						}
					}
				}
			]
		}
	]
}
